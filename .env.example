# Server-side API settings for Vercel Functions.
# Add these in Vercel Project Settings -> Environment Variables.
NIGHT_RENDER_API_BASE_URL=https://www.runninghub.cn
NIGHT_RENDER_API_TOKEN=YOUR_ACCESS_TOKEN
NIGHT_RENDER_API_TIMEOUT_MS=180000
NIGHT_RENDER_API_PROVIDER=runninghub
NIGHT_RENDER_IMAGE_ENDPOINT=/rhart-imagine-image-quality/edit
NIGHT_RENDER_MEDIA_UPLOAD_ENDPOINT=/openapi/v2/media/upload/binary
NIGHT_RENDER_QUERY_ENDPOINT=/openapi/v2/query
NIGHT_RENDER_UPSCALE_ENDPOINT=/run/workflow/2063804310617677826
NIGHT_RENDER_UPSCALE_LOAD_IMAGE_NODE_ID=91
NIGHT_RENDER_UPSCALE_VALUE_NODE_ID=89

# Legacy client-side overrides. Do not put production secrets in VITE_* variables.
VITE_NIGHT_RENDER_API_BASE_URL=https://www.runninghub.cn
VITE_NIGHT_RENDER_API_TIMEOUT_MS=180000
VITE_NIGHT_RENDER_API_PROVIDER=runninghub
VITE_NIGHT_RENDER_API_UPLOAD_MODE=json
VITE_NIGHT_RENDER_IMAGE_ENDPOINT=/rhart-imagine-image-quality/edit
VITE_NIGHT_RENDER_MEDIA_UPLOAD_ENDPOINT=/openapi/v2/media/upload/binary
VITE_NIGHT_RENDER_QUERY_ENDPOINT=/openapi/v2/query
VITE_NIGHT_RENDER_CHAT_ENDPOINT=/v1/chat/completions
VITE_NIGHT_RENDER_IMAGE_MODEL=gpt-image-1
VITE_NIGHT_RENDER_PROMPT_MODEL=gpt-4o-mini
